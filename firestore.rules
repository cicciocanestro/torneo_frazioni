rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive definitions (Phase 3)
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@torneo.local" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Schemas
    function isValidTeam(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.group is string && (data.group == 'A' || data.group == 'B')
        && data.edition is int && data.edition >= 2026;
    }

    function isValidMatch(data) {
      return data.date is string && data.date.size() == 10
        && data.time is string && data.time.size() == 5
        && data.homeTeam is string && data.homeTeam.size() > 0
        && data.awayTeam is string && data.awayTeam.size() > 0
        && data.group is string && (data.group == 'A' || data.group == 'B')
        && data.status is string && (data.status == 'scheduled' || data.status == 'completed')
        && data.edition is int && data.edition >= 2026;
    }

    function isValidScorer(data) {
      return data.player is string && data.player.size() > 0 && data.player.size() <= 100
        && data.team is string && data.team.size() > 0 && data.team.size() <= 100
        && data.goals is int && data.goals >= 0
        && data.edition is int && data.edition >= 2026;
    }

    function isValidSetting(data) {
      return data.edition is int && data.edition >= 2026
        && data.tournamentName is string && data.tournamentName.size() > 0;
    }

    // Rule definitions
    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTeam(request.resource.data);
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidMatch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /scorers/{scorerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidScorer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSetting(request.resource.data);
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read, write: if false;
    }
  }
}
